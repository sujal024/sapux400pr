<mvc:View 
    controllerName = "demo.practice.practice.controller.View10"
    xmlns:core = "sap.ui.core"
    xmlns:mvc = "sap.ui.core.mvc"
    xmlns = "sap.m"
>

<VBox  class = "sapUiSmallMargin" width="20rem">
    <Title text="Static Dropdown (Select)" class = "sapUiSmallMarginBottom"/>

    <Select id = "staticSelect"
            change="onSelectionChange">
            <items>
                <core:Item key = "1" text = "Option 1"/>
                <core:Item key = "2" text = "Option 2"/>
                <core:Item key = "3" text = "Option 3"/>
            </items>
    </Select>
</VBox>
</mvc:View>