<mvc:View 
    controllerName = "demo.practice.practice.controller.View4"
    xmlns:mvc = "sap.ui.core.mvc"
    xmlns = "sap.m"
>

<VBox class="sapUiSmallMargin" width="20rem">
<Title text="password show/hide Toggle" class = "sapUiSmallMarginBottom" />
<Input 
    id = "PasswordInput"
    value = "{/Password}"
    type="{/InputType}"
    placeholder = "Enter Password"
/>

<Button 
    text = "{/buttonText}"
    type = "Emphasized"
    press="onTogglePassword"
    class = "sapUiSmallMarginTop"
/>

</VBox>
</mvc:View>